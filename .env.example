# Google OAuth 2.0 클라이언트 ID (Desktop app, public value)
# Google Cloud Console > APIs & Services > Credentials 에서 발급
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Google OAuth 클라이언트 시크릿은 src-tauri/.env 에 저장 (JS 번들 미포함)
# src-tauri/.env 파일을 만들어서 아래 형식으로 추가:
# GOOGLE_CLIENT_SECRET=your-client-secret-here

# Supabase
# Supabase 대시보드 > Settings > API > Publishable key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here
