{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shop-asset",
  "identifier": "com.yukangchoi.shop-asset",
  "build": {
    "beforeDevCommand": "node scripts/sync-version.js && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/sync-version.js && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "shop-asset",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co https://sheets.googleapis.com https://www.googleapis.com https://accounts.google.com https://oauth2.googleapis.com https://openidconnect.googleapis.com https://api.telegram.org; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFRUVGQ0IwRTY0QjA0MjgKUldRb0JFdm1zUHp1enZPTWk0QTRsSDFreXp3UXJEd3dKRXpBMzhLa2c5STI1WEdZVnNnMFQ5U1IK",
      "endpoints": [
        "https://github.com/Choiyukang/shop-asset/releases/latest/download/latest.json"
      ]
    }
  }
}
